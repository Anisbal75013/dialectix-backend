# ── Dialectix Backend — environment template ──────────────────────────────────
# Copy to .env.development (or .env.production / .env.staging) and fill in real values.
# NEVER commit actual API keys to version control.
#
# The backend loads files in this order (first match wins):
#   1. .env.<NODE_ENV>    e.g. .env.development, .env.production
#   2. .env               shared fallback / CI override
#
# Add all .env* files (except .env.example) to your .gitignore:
#   .env
#   .env.*
#   !.env.example

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/keys
# This key must NEVER be sent to the browser — it lives only in this server file.
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | staging | production
PORT=3001                      # Port the NestJS server binds to

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# Development:  http://localhost:5173,http://localhost:4173
# Production:   https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173

# ── Supabase ───────────────────────────────────────────────────────────────────
# Visible dans : Supabase → Settings → API
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
# ⛔ SERVICE_ROLE_KEY = accès total à la DB — backend UNIQUEMENT, jamais en frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.VOTRE_SERVICE_ROLE_KEY
