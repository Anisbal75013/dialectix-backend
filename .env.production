# ── Dialectix Backend — PRODUCTION environment ────────────────────────────────
# Loaded automatically when NODE_ENV=production (npm run start)
# Set these values in your hosting provider's environment variables panel,
# or populate this file on the server (never commit secrets to git).

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Replace with a production API key (or inject via hosting env vars)
ANTHROPIC_API_KEY=REPLACE_WITH_PRODUCTION_KEY

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
# Replace with your actual production frontend URL(s)
ALLOWED_ORIGINS=https://your-frontend-domain.com
