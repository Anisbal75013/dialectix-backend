# ── Dialectix Backend — STAGING environment ───────────────────────────────────
# Loaded automatically when NODE_ENV=staging (npm run start:stg)

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_STAGING_KEY

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=3001

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://staging.your-frontend-domain.com
